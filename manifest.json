{
  "manifest_version": 3,
  "name": "IAAI Toyota Spec Lookup",
  "version": "1.0",
  "description": "Instantly look up full VIN and Toyota factory packages/options for IAAI listings via SCA Auction",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://www.iaai.com/*",
    "https://*.iaai.com/*",
    "https://sca.auction/*",
    "https://www.toyota.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.iaai.com/*",
        "https://*.iaai.com/*"
      ],
      "js": ["content/iaai.js"],
      "css": ["content/iaai.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
